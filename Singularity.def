# ─── N. gonorrhoeae AMR pipeline — Singularity definition file ───────────────
# Bootstrapped from the Docker image so the two are byte-for-byte identical.
# Build:  singularity build ngono-amr_1.0.sif Singularity.def
# Run:    singularity exec --bind /path/to/amrfinder/data:/amrfinder_db \
#                          ngono-amr_1.0.sif <command>

Bootstrap: docker
From: bkhimek/ngono-amr:1.0

%labels
    Author bkhimek
    Version 1.0
    Description N. gonorrhoeae AMR profiling pipeline

%environment
    export LC_ALL=C
    export PATH=/opt/conda/bin:$PATH

%post
    # AMRFinder database is mounted from the host — nothing to install here
    echo "Image built from bkhimek/ngono-amr:1.0"

%runscript
    exec "$@"

manifest {
    name        = 'ngono-amr'
    description = 'AMR resistance gene detection for N. gonorrhoeae'
    version     = '0.1.0'
}

params {
    prokka_dir       = "${projectDir}/prokka_output"
    genomes_dir      = "${projectDir}/genomes"
    reference_dir    = "${projectDir}/reference"
    results_dir      = "${projectDir}/results/amr"
    reference_strain = "FA1909"

    // AMRFinderPlus
    amrfinder_db     = System.getenv('HOME') + '/miniconda3/share/amrfinderplus/data/latest'
    organism         = "Neisseria"

    // BLAST thresholds
    blast_pident     = 80
    blast_qcov       = 80

    // QRDR windows (amino acid positions, FA-1909 numbering)
    qrdr_gyra_start  = 67
    qrdr_gyra_end    = 106
    qrdr_parc_start  = 57
    qrdr_parc_end    = 96
}

process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'blast' {
        cpus   = 4
        memory = '4 GB'
    }
    withLabel: 'mafft' {
        cpus   = 8
        memory = '8 GB'
    }
    withLabel: 'amrfinder' {
        cpus   = 4
        memory = '8 GB'
    }
    withLabel: 'python' {
        cpus   = 1
        memory = '2 GB'
    }
}

profiles {
    local {
        process.executor = 'local'
    }
    slurm {
        process.executor  = 'slurm'
        process.queue     = 'short'
    }
}

// ─── Execution profiles ───────────────────────────────────────────────────────
profiles {
    local {
        process.executor = 'local'
    }
    docker {
        docker.enabled     = true
        docker.runOptions  = "-u \$(id -u):\$(id -g) -v ${System.getenv('HOME')}/miniconda3/share/amrfinderplus/data:/amrfinder_db"
        process.container  = 'bkhimek/ngono-amr:1.0'
        params.amrfinder_db = '/amrfinder_db/latest'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://bkhimek/ngono-amr:1.0'
    }
}
